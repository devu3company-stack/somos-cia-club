generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Resident {
  id                      String              @id @default(cuid())
  nome                    String
  email                   String              @unique
  cpf                     String              @unique
  senha                   String
  unidade                 String
  external_id             String?
  status                  String              @default("ativo")
  inadimplente            Boolean             @default(false)
  dias_atraso             Int                 @default(0)
  pontos                  Int                 @default(0)
  ultimo_login_verificado DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  couponRedemptions       CouponRedemption[]
  walletTransactions      WalletTransaction[]
}

model Partner {
  id                String             @id @default(cuid())
  nome_fantasia     String
  cnpj              String             @unique
  email             String             @unique
  senha             String
  aprovado          Boolean            @default(false)
  categoria         String
  limite_mensal     Int                @default(1)
  logo_url          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  couponRedemptions CouponRedemption[]
  offers            Offer[]
}

model Offer {
  id        String   @id @default(cuid())
  partnerId String
  titulo    String
  descricao String
  desconto  String
  ativo     Boolean  @default(true)
  image_url String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partner   Partner  @relation(fields: [partnerId], references: [id])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  residentId String
  partnerId  String
  mes_ano    String
  usado_em   DateTime @default(now())
  codigo     String   @unique @default(cuid())
  partner    Partner  @relation(fields: [partnerId], references: [id])
  resident   Resident @relation(fields: [residentId], references: [id])

  @@unique([residentId, partnerId, mes_ano])
}

model WalletTransaction {
  id         String   @id @default(cuid())
  residentId String
  tipo       String
  pontos     Int
  motivo     String
  data       DateTime @default(now())
  resident   Resident @relation(fields: [residentId], references: [id])
}

model PrizeCampaign {
  id             String          @id @default(cuid())
  titulo         String
  descricao      String?
  pontos_minimos Int
  ativo          Boolean         @default(true)
  image_url      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entries        CampaignEntry[]
}

model CampaignEntry {
  id         String        @id @default(cuid())
  campaignId String
  residentId String
  createdAt  DateTime      @default(now())
  campaign   PrizeCampaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, residentId])
}

model Admin {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}
